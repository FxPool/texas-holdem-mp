# Copy to .env (same directory) and fill in. Compose reads it automatically.

# Required: 64-char hex (run `openssl rand -hex 32`)
AUTH_SECRET=

# Optional: set to enable real wx.code2session-based login. When unset,
# /login runs in DEV mode and trusts the client-supplied uid.
WX_APPID=
WX_APPSECRET=
