.action-bar {
  width: 100%;
  padding: 16rpx 24rpx 32rpx;
  background: linear-gradient(180deg, rgba(43, 27, 77, 0) 0%, rgba(43, 27, 77, 0.9) 30%, #1A2B5C 100%);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-bar.is-disabled {
  opacity: 0.45;
  pointer-events: none;
}

.btn-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.act-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 4rpx 0 rgba(0,0,0,0.25);
}

.act-btn.fold {
  background: rgba(255, 107, 122, 0.85);
  color: #FFF6E0;
}

.act-btn.call {
  background: rgba(107, 182, 255, 0.85);
  color: #FFF6E0;
}

.act-btn.raise {
  background: #FFD66B;
  color: #4A2E00;
}

.act-btn:active { transform: translateY(2rpx); }

.act-amount {
  font-size: 26rpx;
  font-weight: 700;
  background: rgba(0,0,0,0.18);
  padding: 2rpx 14rpx;
  border-radius: 16rpx;
}

.act-arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
}

.raise-panel {
  background: rgba(20, 12, 40, 0.92);
  border: 2rpx solid rgba(255, 214, 107, 0.4);
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.quick-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.quick-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 20rpx;
  background: rgba(255, 246, 224, 0.08);
  border: 2rpx solid rgba(255, 246, 224, 0.18);
  color: #FFF6E0;
  font-size: 26rpx;
  font-weight: 700;
}

.quick-btn:active { background: rgba(255, 214, 107, 0.2); }

.slider {
  width: 100%;
  margin: 0;
}

.amount-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.amount-label {
  font-size: 24rpx;
  color: rgba(255, 246, 224, 0.7);
}

.amount-value {
  flex: 1;
  font-size: 36rpx;
  font-weight: 800;
  color: #FFD66B;
}

.confirm-btn {
  padding: 14rpx 36rpx;
  border-radius: 32rpx;
  background: #FFD66B;
  color: #4A2E00;
  font-weight: 800;
  font-size: 28rpx;
}
