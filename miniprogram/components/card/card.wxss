.card-wrap {
  display: inline-block;
  position: relative;
  vertical-align: top;
}

.size-sm { width: 60rpx; height: 88rpx; }
.size-md { width: 88rpx; height: 130rpx; }
.size-lg { width: 120rpx; height: 176rpx; }

.card-face {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  box-shadow:
    0 1rpx 2rpx rgba(0, 0, 0, 0.15),
    0 6rpx 14rpx rgba(0, 0, 0, 0.32);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.card-front {
  background: #FFFFFF;
}

.card-front.color-red { color: #D6294A; }
.card-front.color-black { color: #1A1A22; }

.top-left {
  position: absolute;
  top: 4rpx;
  left: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
  z-index: 2;
}

.top-left .rank {
  font-size: 40rpx;
  font-weight: 900;
  font-family: 'Helvetica Neue', 'Arial Black', 'PingFang SC', sans-serif;
  letter-spacing: -2rpx;
}

.top-left .suit-small {
  font-size: 22rpx;
  margin-top: -2rpx;
  line-height: 1;
}

.suit-big {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  line-height: 1;
  pointer-events: none;
  z-index: 1;
}

/* sm */
.size-sm .top-left { top: 2rpx; left: 6rpx; }
.size-sm .top-left .rank { font-size: 26rpx; letter-spacing: -1rpx; }
.size-sm .top-left .suit-small { font-size: 16rpx; }
.size-sm .suit-big { font-size: 40rpx; bottom: 4rpx; }

/* lg */
.size-lg .top-left { top: 6rpx; left: 14rpx; }
.size-lg .top-left .rank { font-size: 56rpx; letter-spacing: -3rpx; }
.size-lg .top-left .suit-small { font-size: 30rpx; }
.size-lg .suit-big { font-size: 82rpx; bottom: 10rpx; }

.card-back {
  background:
    repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.06) 0 6rpx,
      transparent 6rpx 14rpx
    ),
    linear-gradient(135deg, #7A5BD9 0%, #4A2F9E 50%, #2B1B4D 100%);
  border: 3rpx solid #FFD66B;
  box-sizing: border-box;
  box-shadow:
    0 1rpx 2rpx rgba(0, 0, 0, 0.15),
    0 6rpx 14rpx rgba(0, 0, 0, 0.32),
    inset 0 0 12rpx rgba(0, 0, 0, 0.35);
}

.back-pattern {
  position: absolute;
  inset: 6rpx;
  border: 1rpx dashed rgba(255, 214, 107, 0.55);
  border-radius: 6rpx;
}

.back-pattern::after {
  content: '♠';
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 214, 107, 0.5);
  font-size: 40rpx;
}

.size-sm .back-pattern::after { font-size: 24rpx; }
.size-lg .back-pattern::after { font-size: 56rpx; }

.card-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  border: 2rpx dashed rgba(255, 246, 224, 0.3);
  background: rgba(255, 255, 255, 0.03);
  box-sizing: border-box;
}
