.card-wrap {
  display: inline-block;
  position: relative;
  vertical-align: top;
}

.size-sm { width: 60rpx; height: 88rpx; }
.size-md { width: 88rpx; height: 130rpx; }
.size-lg { width: 120rpx; height: 176rpx; }

.card-face {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.18),
    0 8rpx 18rpx rgba(0, 0, 0, 0.28),
    inset 0 0 0 1rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.card-front {
  background:
    linear-gradient(160deg, #FFFFFF 0%, #FFFBF0 55%, #F4E9CC 100%);
  padding: 6rpx 8rpx;
}

.card-front::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 12rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.9);
  pointer-events: none;
}

.card-front.color-red { color: #D6294A; }
.card-front.color-black { color: #1F1F2C; }

.corner {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
  z-index: 2;
}

.top-left {
  top: 6rpx;
  left: 8rpx;
}

.bottom-right {
  bottom: 6rpx;
  right: 8rpx;
  transform: rotate(180deg);
}

.corner .rank {
  font-size: 32rpx;
  font-weight: 900;
  font-family: 'Helvetica Neue', 'PingFang SC', sans-serif;
  letter-spacing: -1rpx;
}

.corner .suit {
  font-size: 22rpx;
  margin-top: 1rpx;
  line-height: 1;
}

.center-suit {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  opacity: 0.18;
  pointer-events: none;
  z-index: 1;
}

/* sm */
.size-sm .top-left { top: 4rpx; left: 5rpx; }
.size-sm .bottom-right { bottom: 4rpx; right: 5rpx; }
.size-sm .corner .rank { font-size: 22rpx; }
.size-sm .corner .suit { font-size: 16rpx; }
.size-sm .center-suit { font-size: 44rpx; }

/* lg */
.size-lg .top-left { top: 8rpx; left: 12rpx; }
.size-lg .bottom-right { bottom: 8rpx; right: 12rpx; }
.size-lg .corner .rank { font-size: 44rpx; }
.size-lg .corner .suit { font-size: 30rpx; }
.size-lg .center-suit { font-size: 96rpx; }

.card-back {
  background:
    repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.06) 0 6rpx,
      transparent 6rpx 14rpx
    ),
    linear-gradient(135deg, #7A5BD9 0%, #4A2F9E 50%, #2B1B4D 100%);
  border: 3rpx solid #FFD66B;
  box-sizing: border-box;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.18),
    0 8rpx 18rpx rgba(0, 0, 0, 0.28),
    inset 0 0 12rpx rgba(0, 0, 0, 0.35);
}

.back-pattern {
  position: absolute;
  inset: 6rpx;
  border: 1rpx dashed rgba(255, 214, 107, 0.55);
  border-radius: 6rpx;
}

.back-pattern::after {
  content: '♠';
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 214, 107, 0.5);
  font-size: 40rpx;
}

.size-sm .back-pattern::after { font-size: 24rpx; }
.size-lg .back-pattern::after { font-size: 56rpx; }

.card-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  border: 2rpx dashed rgba(255, 246, 224, 0.3);
  background: rgba(255, 255, 255, 0.03);
  box-sizing: border-box;
}
