.community {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  justify-content: center;
  /* 预热合成层,避免每次翻牌瞬间临时建层导致的首帧抖动 */
  transform: translateZ(0);
  backface-visibility: hidden;
}

.slot {
  display: flex;
  align-items: center;
  justify-content: center;
  backface-visibility: hidden;
}

/* Per-card flip-in: a single card scales up + tilts as it lands.
   `both` fill-mode applies the 0% (hidden) state during animation-delay,
   so staggered cards in a flop stay invisible until their turn. */
.slot.is-flipping {
  animation: card-flip-in 0.55s cubic-bezier(0.34, 1.4, 0.64, 1) both;
  transform-origin: center;
  will-change: transform, opacity;
}

@keyframes card-flip-in {
  0%   { transform: rotateY(180deg) scale(0.5); opacity: 0; }
  35%  { opacity: 1; }
  60%  { transform: rotateY(-12deg) scale(1.08); }
  100% { transform: rotateY(0deg) scale(1); opacity: 1; }
}
