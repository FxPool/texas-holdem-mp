.pot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.chip-stack {
  position: relative;
  width: 64rpx;
  height: 70rpx;
}

.chip {
  position: absolute;
  left: 0;
  width: 64rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.25);
  box-shadow: inset 0 -3rpx 0 rgba(0,0,0,0.18), 0 2rpx 0 rgba(0,0,0,0.2);
}

.chip-1 { bottom: 0; background: #FF6B7A; }
.chip-2 { bottom: 12rpx; background: #6BB6FF; }
.chip-3 { bottom: 24rpx; background: #FFD66B; }
.chip-4 { bottom: 36rpx; background: #7FCBA4; }
.chip-5 { bottom: 48rpx; background: #C49AE8; }

.pot-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pot-label {
  font-size: 22rpx;
  color: rgba(255, 246, 224, 0.7);
  letter-spacing: 4rpx;
}

.pot-amount {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFD66B;
  text-shadow: 0 2rpx 0 rgba(0,0,0,0.3);
  line-height: 1.1;
}

.pot-bet {
  font-size: 20rpx;
  color: rgba(255, 246, 224, 0.85);
  margin-top: 2rpx;
}
