.overlay {
  position: fixed;
  inset: 0;
  background: rgba(20, 12, 40, 0.75);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fade-in 0.25s ease-out;
}

@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.panel {
  width: 86%;
  max-height: 80vh;
  background: linear-gradient(180deg, #2B1B4D 0%, #1A2B5C 100%);
  border: 3rpx solid rgba(255, 214, 107, 0.5);
  border-radius: 32rpx;
  padding: 32rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.5);
  animation: slide-up 0.35s cubic-bezier(0.34, 1.4, 0.64, 1);
}

@keyframes slide-up {
  from { transform: translateY(40rpx); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFD66B;
  letter-spacing: 6rpx;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 246, 224, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFF6E0;
  font-size: 36rpx;
  line-height: 1;
}

.uncontested {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx 0;
}

.uncontested .winner-name {
  font-size: 42rpx;
  font-weight: 800;
  color: #FFD66B;
}

.uncontested .winner-amount {
  font-size: 56rpx;
  font-weight: 900;
  color: #FFD66B;
  text-shadow: 0 2rpx 0 rgba(0,0,0,0.3);
}

.uncontested .hint {
  font-size: 24rpx;
  color: rgba(255, 246, 224, 0.6);
}

.contestant-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.contestant {
  background: rgba(255, 246, 224, 0.05);
  border: 2rpx solid rgba(255, 246, 224, 0.12);
  border-radius: 20rpx;
  padding: 16rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.contestant.is-winner {
  background: rgba(255, 214, 107, 0.15);
  border-color: rgba(255, 214, 107, 0.7);
  box-shadow: 0 0 16rpx rgba(255, 214, 107, 0.3);
}

.row-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar-bubble {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF6E0, #FFD66B);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.avatar-bubble .avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-emoji {
  font-size: 38rpx;
}

.head-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFF6E0;
}

.rank {
  font-size: 22rpx;
  color: #FFD66B;
}

.winner-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #FFD66B;
  color: #4A2E00;
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  font-weight: 800;
}

.trophy { font-size: 22rpx; }
.amount { font-size: 26rpx; }

.cards-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-left: 8rpx;
}

.hole-cards { display: flex; gap: 8rpx; }
.community-cards { display: flex; gap: 4rpx; }

.plus {
  color: rgba(255, 246, 224, 0.5);
  font-size: 28rpx;
  margin: 0 4rpx;
}

.continue-btn {
  align-self: stretch;
  text-align: center;
  background: #FFD66B;
  color: #4A2E00;
  font-size: 30rpx;
  font-weight: 800;
  padding: 20rpx 0;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 0 #E0A744;
}

.continue-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 0 #E0A744;
}
