.page {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 60rpx 80rpx;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.logo {
  font-size: 220rpx;
  line-height: 1;
  filter: drop-shadow(0 8rpx 16rpx rgba(0,0,0,0.4));
}

.title {
  font-size: 72rpx;
  font-weight: 900;
  color: #FFD66B;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 0 rgba(0,0,0,0.3);
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 246, 224, 0.7);
}

.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 800;
}

.btn.primary {
  background: #FFD66B;
  color: #4A2E00;
  box-shadow: 0 6rpx 0 #E0A744;
}

.btn.primary:active { transform: translateY(2rpx); box-shadow: 0 4rpx 0 #E0A744; }

.btn.ghost {
  background: transparent;
  color: rgba(255, 246, 224, 0.85);
  border: 2rpx solid rgba(255, 246, 224, 0.35);
}

.footer {
  font-size: 22rpx;
  color: rgba(255, 246, 224, 0.4);
}

/* 微信资料授权弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(8, 4, 22, 0.78);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.modal-card {
  width: 100%;
  max-width: 600rpx;
  background: linear-gradient(180deg, #2B1B4D 0%, #1A2B5C 100%);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 214, 107, 0.45);
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.55);
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.modal-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #FFD66B;
}
.modal-sub {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 246, 224, 0.6);
  margin-top: -10rpx;
  line-height: 1.5;
}

.profile-avatar-row {
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-pick-btn {
  background: rgba(20, 12, 40, 0.55);
  border: 2rpx dashed rgba(255, 214, 107, 0.5);
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 320rpx;
}
.avatar-pick-btn::after { border: none; }
.profile-avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 214, 107, 0.18);
}
.profile-avatar-emoji {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 214, 107, 0.18);
  font-size: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-pick-tip {
  font-size: 22rpx;
  color: rgba(255, 246, 224, 0.7);
}

.modal-section { display: flex; flex-direction: column; gap: 10rpx; }
.modal-label {
  font-size: 26rpx;
  color: rgba(255, 246, 224, 0.72);
  font-weight: 600;
}
.modal-hint {
  font-size: 22rpx;
  color: rgba(255, 246, 224, 0.45);
}
.modal-input {
  background: rgba(20, 12, 40, 0.6);
  border: 2rpx solid rgba(255, 246, 224, 0.16);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  color: #FFF6E0;
  font-size: 28rpx;
}

.modal-actions { display: flex; flex-direction: row; gap: 16rpx; margin-top: 8rpx; }
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}
.modal-btn-ghost {
  background: rgba(255, 246, 224, 0.1);
  color: rgba(255, 246, 224, 0.8);
  border: 2rpx solid rgba(255, 246, 224, 0.2);
}
.modal-btn-primary {
  background: #FFD66B;
  color: #4A2E00;
  box-shadow: 0 4rpx 0 #E0A744;
}
.modal-btn-primary.is-busy { opacity: 0.7; }
.modal-btn:active { transform: scale(0.98); }
