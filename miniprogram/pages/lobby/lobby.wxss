.page {
  width: 100vw;
  min-height: 100vh;
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 8rpx 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #FFF6E0;
}

.create-btn {
  background: #FFD66B;
  color: #4A2E00;
  font-size: 28rpx;
  font-weight: 700;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 0 #E0A744;
}

.me-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx;
  background: rgba(255, 214, 107, 0.1);
  border: 2rpx solid rgba(255, 214, 107, 0.3);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}

.me-card .me-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF6E0, #FFD66B);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.me-card .me-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.me-card .me-label {
  font-size: 22rpx;
  color: rgba(255, 246, 224, 0.6);
}

.me-card .me-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFD66B;
}

.room-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.room-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 28rpx;
  background: rgba(255, 246, 224, 0.08);
  border: 2rpx solid rgba(255, 246, 224, 0.12);
  border-radius: 24rpx;
}

.room-card:active {
  background: rgba(255, 214, 107, 0.15);
}

.room-icon {
  font-size: 64rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7FCBA4, #3E8E5E);
  display: flex;
  align-items: center;
  justify-content: center;
}

.room-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFF6E0;
}

.room-meta {
  font-size: 24rpx;
  color: rgba(255, 246, 224, 0.6);
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}

.dot { opacity: 0.4; }

.room-id {
  font-size: 26rpx;
  color: #FFD66B;
  font-weight: 700;
}

.room-id-empty {
  font-size: 22rpx;
  color: rgba(255, 246, 224, 0.55);
  border: 2rpx dashed rgba(255, 246, 224, 0.3);
  padding: 4rpx 14rpx;
  border-radius: 18rpx;
  font-weight: 600;
}
