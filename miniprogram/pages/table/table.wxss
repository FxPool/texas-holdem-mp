.page {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #2B1B4D 0%, #1A2B5C 100%);
  position: relative;
  overflow: hidden;
}

.page::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(255,255,255,0.6), transparent),
    radial-gradient(2rpx 2rpx at 70% 15%, rgba(255,255,255,0.4), transparent),
    radial-gradient(3rpx 3rpx at 80% 60%, rgba(255,214,107,0.5), transparent),
    radial-gradient(2rpx 2rpx at 30% 80%, rgba(255,255,255,0.3), transparent);
  pointer-events: none;
}

/* 顶部栏 */
.topbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  z-index: 10;
  position: relative;
}

.topbar-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 246, 224, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 246, 224, 0.2);
}

.topbar-btn .icon {
  font-size: 32rpx;
  color: #FFF6E0;
}

.topbar-title {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 10rpx;
  background: rgba(20, 12, 40, 0.6);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255, 214, 107, 0.3);
}

.room-label { font-size: 22rpx; color: rgba(255, 246, 224, 0.6); }
.room-id { font-size: 30rpx; font-weight: 800; color: #FFD66B; }
.blinds { font-size: 22rpx; color: rgba(255, 246, 224, 0.7); margin-left: 6rpx; }

/* 加载/错误提示横幅：以覆盖层形式悬浮在 stage-tag 上方，
   不参与 flex 主轴的高度计算，避免显隐切换抖动 table-zone */
.banner-overlay {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  z-index: 20;
  pointer-events: none;
}
.banner {
  pointer-events: auto;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(20, 12, 40, 0.88);
  border: 2rpx solid rgba(255, 214, 107, 0.4);
  color: #FFD66B;
  font-size: 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.35);
}

/* 阶段标签：固定在顶栏下方居中，独立一行 */
.stage-tag {
  align-self: center;
  margin: 8rpx 0 0;
  background: rgba(255, 214, 107, 0.15);
  color: #FFD66B;
  padding: 4rpx 24rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  border: 2rpx solid rgba(255, 214, 107, 0.4);
  z-index: 5;
}

/* 桌面区 */
.table-zone {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 20rpx;
  min-height: 0;
}

.felt {
  position: relative;
  width: 92%;
  height: 100%;
  border-radius: 50%;
}

.felt-inner {
  position: absolute;
  inset: 36rpx;
  border-radius: 50%;
  background:
    radial-gradient(ellipse at center, #7FCBA4 0%, #4FA274 60%, #3E8E5E 100%);
  border: 12rpx solid #F4B6A0;
  box-shadow:
    inset 0 0 60rpx rgba(0,0,0,0.25),
    0 12rpx 30rpx rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.felt-inner::before {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 214, 107, 0.5);
  pointer-events: none;
}

.center-stack {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.pot-row {
  margin-top: 4rpx;
}

/* 对手座位绝对定位在 felt 上 */
.seat-pos {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 5;
}

/* 我的私人区域 */
.me-zone {
  margin: 0 24rpx 8rpx;
  padding: 12rpx 20rpx 16rpx;
  border-radius: 28rpx;
  background: rgba(20, 12, 40, 0.55);
  border: 2rpx solid rgba(255, 246, 224, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  position: relative;
  z-index: 6;
}

.me-zone.is-my-turn {
  border-color: rgba(255, 214, 107, 0.7);
  box-shadow: 0 0 20rpx rgba(255, 214, 107, 0.3);
}

.me-cards {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: -64rpx; /* 让手牌探出 me-zone 顶部，更立体 */
  margin-bottom: 4rpx;
  position: relative;
}

.me-cards.is-revealed .me-cards-hint { display: none; }

.me-cards-hint {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  font-weight: 700;
  color: #FFF6E0;
  background: rgba(20, 12, 40, 0.78);
  border: 2rpx solid rgba(255, 214, 107, 0.5);
  padding: 6rpx 16rpx;
  border-radius: 18rpx;
  white-space: nowrap;
  pointer-events: none;
  z-index: 2;
  animation: hint-pulse 1.6s ease-in-out infinite;
}

@keyframes hint-pulse {
  0%, 100% { opacity: 0.85; }
  50%      { opacity: 1; }
}

/* 摊牌时自己的中文牌型标签，浮在两张牌中间正上方 */
.me-hand-rank {
  position: absolute;
  left: 50%;
  top: -38rpx;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #FFD66B 0%, #FFA94D 100%);
  color: #4A2E00;
  font-size: 26rpx;
  font-weight: 800;
  padding: 4rpx 20rpx;
  border-radius: 18rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.45);
  letter-spacing: 2rpx;
  white-space: nowrap;
  z-index: 3;
}

.me-card-tilt {
  display: inline-block;
}

.me-card-tilt.tilt-0 { transform: rotate(-5deg); }
.me-card-tilt.tilt-1 { transform: rotate(5deg); }

.me-info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.me-avatar-wrap {
  position: relative;
  width: 84rpx;
  height: 84rpx;
}

.me-active-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 4rpx solid #FFD66B;
  box-shadow: 0 0 16rpx #FFD66B;
  animation: ring-pulse 1.4s ease-in-out infinite;
  will-change: transform, opacity;
}

@keyframes ring-pulse {
  0%, 100% { transform: scale(1);    opacity: 0.85; }
  50%      { transform: scale(1.08); opacity: 1;    }
}

.me-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF6E0 0%, #FFD66B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 246, 224, 0.4);
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.3);
  overflow: hidden;
}
.me-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.me-avatar-emoji {
  font-size: 50rpx;
  line-height: 1;
}

.me-badge {
  position: absolute;
  bottom: -4rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 18rpx;
  font-size: 20rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.me-badge-d { background: #FFD66B; color: #4A2E00; }
.me-badge-sb { background: #6BB6FF; color: #fff; }
.me-badge-bb { background: #FF6B7A; color: #fff; }
.me-badge-utg { background: #B879FF; color: #fff; }

.me-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.me-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFF6E0;
}

.me-chips-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.me-chips-icon { color: #FFD66B; font-size: 22rpx; }
.me-chips { font-size: 30rpx; color: #FFD66B; font-weight: 800; }

.me-bet {
  background: rgba(255, 214, 107, 0.18);
  border: 2rpx solid #FFD66B;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.me-bet-icon { color: #FFD66B; font-size: 18rpx; }
.me-bet-num { font-size: 22rpx; color: #FFD66B; font-weight: 700; }

.rebuy-btn {
  background: #FFD66B;
  color: #4A2E00;
  font-size: 24rpx;
  font-weight: 800;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 3rpx 0 #E0A744;
}
.rebuy-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 0 #E0A744;
}

.rebuy-btn-disabled {
  background: rgba(255, 246, 224, 0.18);
  color: rgba(255, 246, 224, 0.6);
  box-shadow: none;
}
.rebuy-btn-disabled:active {
  transform: none;
  box-shadow: none;
}

/* ========================================
   动画层
   ======================================== */

/* 发牌动画：单张牌从桌中飞向座位。
   每张牌通过 inline animation-delay 错峰发出（依次发牌效果）；
   animation-fill-mode: both 让延迟期间保持 0% 状态（隐形居中），
   动画结束后保留 100% 状态（已淡出）。
   --dx / --dy 是 felt 中心到目标的 px 偏移，由 JS 测量后写入 inline style，
   keyframes 只动 transform 让浏览器走合成层而不重排。 */
.deal-card {
  position: absolute;
  width: 60rpx;
  height: 88rpx;
  border-radius: 12rpx;
  border: 3rpx solid #FFD66B;
  background: repeating-linear-gradient(
    45deg,
    #6B4FBC 0 8rpx,
    #4A3590 8rpx 16rpx
  );
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.4);
  top: 50%;
  left: 50%;
  pointer-events: none;
  z-index: 20;
  will-change: transform, opacity;
}

.deal-card.deal-to-me {
  animation: deal-to-me 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
}

@keyframes deal-to-me {
  0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.4); }
  15%  { opacity: 1; }
  100% { opacity: 0; transform: translate(-50%, calc(-50% + var(--dy, 240px))) scale(1); }
}

.deal-card.deal-to-pos {
  animation: deal-to-pos 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
}

@keyframes deal-to-pos {
  0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.4); }
  15%  { opacity: 1; }
  100% { opacity: 0;
         transform: translate(calc(-50% + var(--dx, 0px)), calc(-50% + var(--dy, 0px))) scale(1); }
}

/* 筹码飞入动画：from/to 用 px 偏移走 transform。 */
.chip-fly {
  position: absolute;
  top: 50%;
  left: 50%;
  pointer-events: none;
  z-index: 25;
  animation: chip-fly 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  will-change: transform, opacity;
}

@keyframes chip-fly {
  0%   { opacity: 0.8;
         transform: translate(calc(-50% + var(--from-x, 0px)), calc(-50% + var(--from-y, 0px))) scale(0.6); }
  20%  { opacity: 1; }
  100% { opacity: 0;
         transform: translate(calc(-50% + var(--to-x, 0px)), calc(-50% + var(--to-y, 0px))) scale(1.1); }
}

.chip-fly .chip-disc {
  width: 36rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #FFD66B, #E0A744);
  border: 2rpx solid rgba(0,0,0,0.25);
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.chip-fly .chip-amount {
  font-size: 22rpx;
  color: #FFD66B;
  font-weight: 800;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.6);
}

/* 聊天气泡：玩家附近浮起再消散 */
.chat-bubble {
  position: absolute;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 30;
  background: rgba(20, 12, 40, 0.92);
  border: 2rpx solid rgba(255, 214, 107, 0.6);
  border-radius: 32rpx;
  padding: 8rpx 18rpx;
  animation: chat-float 2.2s ease-out forwards;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.4);
  will-change: transform, opacity;
}

.chat-bubble-emoji {
  font-size: 40rpx;
  line-height: 1;
}

@keyframes chat-float {
  0%   { opacity: 0; transform: translate(-50%, -30%) scale(0.6); }
  20%  { opacity: 1; transform: translate(-50%, -90%) scale(1); }
  80%  { opacity: 1; transform: translate(-50%, -120%) scale(1); }
  100% { opacity: 0; transform: translate(-50%, -150%) scale(0.95); }
}

/* 赢家盈利数字：从座位上方浮出、上飘、淡出 */
.win-bubble {
  position: absolute;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 32;
  font-size: 40rpx;
  font-weight: 900;
  color: #5BE5A6;
  text-shadow:
    0 2rpx 6rpx rgba(0, 0, 0, 0.6),
    0 0 12rpx rgba(91, 229, 166, 0.6);
  animation: win-float 1.8s cubic-bezier(0.2, 0.8, 0.3, 1) forwards;
  white-space: nowrap;
  will-change: transform, opacity;
}

@keyframes win-float {
  0%   { opacity: 0; transform: translate(-50%, 0%)    scale(0.6); }
  15%  { opacity: 1; transform: translate(-50%, -80%)  scale(1.25); }
  60%  { opacity: 1; transform: translate(-50%, -160%) scale(1.05); }
  100% { opacity: 0; transform: translate(-50%, -220%) scale(1); }
}

/* 表情选择器 */
.chat-backdrop {
  position: absolute;
  inset: 0;
  z-index: 40;
  background: rgba(0, 0, 0, 0.25);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 220rpx;
}

.chat-picker {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  background: rgba(20, 12, 40, 0.95);
  border: 2rpx solid rgba(255, 214, 107, 0.4);
  border-radius: 24rpx;
  padding: 18rpx 18rpx;
  width: 86%;
}

.chat-pick-btn {
  font-size: 50rpx;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 16rpx;
  background: rgba(255, 246, 224, 0.06);
  border: 2rpx solid rgba(255, 246, 224, 0.12);
  line-height: 1;
}
.chat-pick-btn:active {
  background: rgba(255, 214, 107, 0.2);
}

/* 操作区 */
.action-zone {
  position: relative;
  z-index: 10;
}

.chat-trigger {
  position: absolute;
  right: 24rpx;
  top: -88rpx;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(20, 12, 40, 0.85);
  border: 2rpx solid rgba(255, 214, 107, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  z-index: 11;
}
.chat-trigger:active {
  transform: scale(0.95);
}

/* 等待提示：用 absolute 浮在 action-bar 顶部正上方原位，不占布局高度，
   切换显隐时 table-zone 高度恒定 */
.wait-tip {
  position: absolute;
  left: 50%;
  bottom: calc(100% - 8rpx);
  transform: translateX(-50%);
  white-space: nowrap;
  font-size: 22rpx;
  color: rgba(255, 246, 224, 0.85);
  padding: 6rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(20, 12, 40, 0.85);
  border: 2rpx solid rgba(255, 214, 107, 0.32);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  pointer-events: none;
  z-index: 12;
}

/* 倒计时徽章 */
.countdown {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  margin-left: 12rpx;
  padding: 4rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(76, 211, 255, 0.15);
  border: 2rpx solid rgba(76, 211, 255, 0.45);
  color: #4CD3FF;
  font-size: 22rpx;
}
.countdown.is-pending {
  background: rgba(255, 153, 102, 0.2);
  border-color: rgba(255, 153, 102, 0.6);
  color: #FF9966;
}
.countdown.is-ended {
  background: rgba(255, 100, 100, 0.2);
  border-color: rgba(255, 100, 100, 0.6);
  color: #FF6B6B;
}
.countdown-icon {
  font-size: 22rpx;
}
.countdown-text {
  font-weight: 700;
}

.banner-end {
  background: rgba(255, 153, 102, 0.16);
  border-color: rgba(255, 153, 102, 0.5);
  color: #FF9966;
}

/* 终局结算 */
.settlement-mask {
  position: fixed;
  inset: 0;
  background: rgba(8, 4, 22, 0.78);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}
.settlement-panel {
  width: 100%;
  max-width: 640rpx;
  background: linear-gradient(180deg, #2B1B4D 0%, #1A2B5C 100%);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 214, 107, 0.45);
  padding: 32rpx 28rpx 24rpx;
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.55);
}
.settlement-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #FFD66B;
  margin-bottom: 6rpx;
}
.settlement-sub {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 246, 224, 0.55);
  margin-bottom: 20rpx;
}
.settlement-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  max-height: 60vh;
  overflow-y: auto;
}
.settlement-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(20, 12, 40, 0.55);
  border: 2rpx solid rgba(255, 246, 224, 0.08);
}
.settlement-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 214, 107, 0.18);
  color: #FFD66B;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}
.settlement-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(76, 211, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  overflow: hidden;
}
.settlement-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.settlement-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.settlement-name {
  color: #FFF6E0;
  font-size: 28rpx;
  font-weight: 700;
}
.settlement-detail {
  color: rgba(255, 246, 224, 0.55);
  font-size: 22rpx;
}
.settlement-net {
  font-size: 30rpx;
  font-weight: 800;
  color: rgba(255, 246, 224, 0.7);
  min-width: 120rpx;
  text-align: right;
}
.settlement-net.win { color: #5BE5A6; }
.settlement-net.lose { color: #FF6B6B; }
.settlement-back {
  margin-top: 24rpx;
  padding: 18rpx 0;
  border-radius: 16rpx;
  background: rgba(255, 214, 107, 0.18);
  color: #FFD66B;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  border: 2rpx solid rgba(255, 214, 107, 0.5);
}
.settlement-back:active { opacity: 0.8; }
